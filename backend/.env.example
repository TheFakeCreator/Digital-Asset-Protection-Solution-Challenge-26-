PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sports-media-protection
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=uploads
CRAWLER_OUTPUT_DIR=data/crawled/twitter
REDIS_URL=redis://localhost:6379
MAX_UPLOAD_SIZE_MB=10
PYTHON_EXECUTABLE=python
# If modules are missing on your default python, set an absolute path e.g. C:/Python314/python.exe
PYTHON_FINGERPRINT_SCRIPT=python/fingerprint_service.py
PYTHON_DETECTION_SCRIPT=python/detection_service.py
PYTHON_BRIDGE_TIMEOUT_MS=30000
DETECTION_SIMILARITY_THRESHOLD=85
DETECTION_CACHE_TTL_SECONDS=900
DETECTION_MAX_PENDING_JOBS=100
DETECTION_BATCH_CONCURRENCY=3
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SolutionChallengeCrawler/1.0
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# MongoDB Atlas example (set this value in .env.local when ready)
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/sports-media-protection?retryWrites=true&w=majority
